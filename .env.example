DATABASE_URL=postgresql://username:password@host/database?sslmode=require
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# Must use an address on a domain you verify in Resend.
RESEND_FROM_EMAIL="BlackArrow Insurance <forms@blackarrow.co>"

# ---- Monthly auto-post cron job ----
# Bearer token Vercel Cron uses to authenticate /api/cron/generate-monthly-post.
# Generate a strong random value (e.g. `openssl rand -hex 32`) and set it in Vercel project env vars.
CRON_SECRET=replace_with_openssl_rand_hex_32

# Claude API key used to generate monthly NC blog posts. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# Optional: set to "true" to auto-publish. Any other value (or unset) saves the post as a draft.
AUTO_PUBLISH_POSTS=false

# Optional: user id to attribute auto-generated posts to. Leave empty for null author.
AUTO_POST_AUTHOR_ID=

# Optional: override the Anthropic model used for generation.
AUTO_POST_MODEL=claude-sonnet-4-6
